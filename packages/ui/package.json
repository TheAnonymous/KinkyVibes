{
  "name": "@kinky-vibes/ui",
  "version": "1.0.0",
  "description": "Industrial-underground Vue 3 components with no UI runtime dependencies.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./dist/tokens.css"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && vue-tsc -p tsconfig.build.json --emitDeclarationOnly && vite build && node scripts/copy-assets.mjs",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "vue": ">=3.5 <4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheAnonymous/KinkyVibes.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "vue",
    "components",
    "design-system",
    "typescript",
    "accessible"
  ]
}
