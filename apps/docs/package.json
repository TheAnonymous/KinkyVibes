{
  "name": "@kinky-vibes/docs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @kinky-vibes/ui",
    "dev": "vite --host 0.0.0.0",
